# School Library Management System - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ============================================
# Database Configuration
# ============================================

# For SQL Server
# DatabaseConnection=Server=localhost;Database=SchoolLibraryDB;Trusted_Connection=true;Encrypt=false

# For SQLite (Development)
DatabaseConnection=Data Source=schoollibrary.db

# ============================================
# JWT Authentication
# ============================================

# Secret key for signing JWT tokens (minimum 32 characters)
JwtSecret=YourSuperSecretKeyWith32CharactersMinimumLength

# JWT issuer
JwtIssuer=SchoolLibraryApp

# JWT audience
JwtAudience=SchoolLibraryUsers

# Token expiration time in minutes
JwtExpirationMinutes=60

# ============================================
# Application Configuration
# ============================================

# Application URL
AppUrl=http://localhost:5000

# Allowed CORS origins (comma-separated)
AllowedOrigins=http://localhost:3000,http://localhost:5173

# Application environment
ASPNETCORE_ENVIRONMENT=Development

# ============================================
# Email Configuration (Optional)
# ============================================

# SMTP Server settings
SmtpServer=smtp.gmail.com
SmtpPort=587
SmtpUsername=your-email@gmail.com
SmtpPassword=your-app-password
SmtpFromAddress=library@school.edu
SmtpFromName=School Library

# ============================================
# Logging Configuration
# ============================================

# Log level (Debug, Information, Warning, Error, Critical)
LogLevel=Information

# Log file path
LogPath=logs/

# ============================================
# Library Configuration
# ============================================

# Maximum number of books a student can borrow
MaxBooksPerStudent=5

# Maximum number of books a teacher can borrow
MaxBooksPerTeacher=10

# Default loan period for students (days)
LoanPeriodDays=14

# Default loan period for teachers (days)
TeacherLoanPeriodDays=21

# Fine amount per day (currency units)
FinePerDay=0.50

# Maximum fine per book
MaxFinePerBook=10.00

# ============================================
# Security Configuration
# ============================================

# Password requirements
PasswordMinLength=8
PasswordRequireUppercase=true
PasswordRequireLowercase=true
PasswordRequireDigits=true
PasswordRequireSpecialChars=true

# Account lockout settings
MaxFailedLoginAttempts=5
LockoutDurationMinutes=15

# ============================================
# Feature Flags
# ============================================

# Enable/Disable features
EnableReservations=false
EnableEBooks=false
EnableNotifications=false
EnableMobileApp=false

# ============================================
# API Configuration
# ============================================

# Rate limiting
RateLimitRequests=100
RateLimitWindow=60

# API documentation
EnableSwagger=true
EnableSwaggerUI=true
